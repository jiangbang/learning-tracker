{
  "name": "learning-tracker-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create learning-tracker-db",
    "db:init": "wrangler d1 execute learning-tracker-db --file ../scripts/init-db.sql",
    "db:seed": "wrangler d1 execute learning-tracker-db --file ../scripts/seed-db.sql"
  },
  "dependencies": {
    "hono": "^4.3.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240529.0",
    "typescript": "^5.4.5",
    "wrangler": "^4.75.0"
  }
}
